{
  "name": "joy-crm-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true})\"",
    "predev": "npm run clean",
    "prebuild": "npm run clean",
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "doctor": "node -v && npm -v && npm ls next react react-dom eslint-config-next"
  },
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "dependencies": {
